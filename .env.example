# ========================================
# BlockSentinel Environment Configuration
# ========================================

# -----------------
# Frontend (Next.js)
# -----------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your_thirdweb_client_id_here

# -----------------
# Backend (FastAPI)
# -----------------

# Database Configuration
# For Supabase: postgresql://postgres.PROJECT_REF:PASSWORD@aws-X-REGION.pooler.supabase.com:6543/postgres
# For Local PostgreSQL: postgresql://user:password@localhost:5432/blocksentinel
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-X-REGION.pooler.supabase.com:6543/postgres

# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_STORAGE_BUCKET=scan-reports

# Etherscan API
# Get free API key from: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Security
# Generate a random 32+ character string
SECRET_KEY=change-this-to-a-random-secret-key-minimum-32-characters
DEBUG=True
LOG_LEVEL=INFO

# API Configuration
API_V1_PREFIX=/api/v1
PROJECT_NAME=BlockSentinel
VERSION=1.0.0

# CORS Configuration
FRONTEND_URL=http://localhost:3000

# -----------------
# AI Analysis (Ollama)
# -----------------
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
AI_PROVIDER=ollama

# -----------------
# File Storage
# -----------------
REPORTS_DIR=./reports
MAX_UPLOAD_SIZE_MB=10

# -----------------
# Analysis Timeouts
# -----------------
SLITHER_TIMEOUT=120
DOCKER_TIMEOUT=300
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# -----------------
# Notes
# -----------------
# 1. Copy this file to .env and fill in your actual values
# 2. Never commit .env to version control
# 3. Use URL-encoded passwords if they contain special characters (#, @, etc.)
# 4. For Supabase, use the connection pooler URL (port 6543) not direct connection
# 5. Ensure Ollama is running (ollama serve) before starting backend
# 6. Create the 'scan-reports' bucket in Supabase Storage and set it to Public
